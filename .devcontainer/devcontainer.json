{
  "name": "Vitals Publisher (Python 3.11)",
  "image": "python:3.11-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "eamodio.gitlens",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && pip install pytest pytest-cov black flake8 mypy pylint isort",
  "forwardPorts": [1883],
  "portsAttributes": {
    "1883": {
      "label": "MQTT Broker",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "root"
}