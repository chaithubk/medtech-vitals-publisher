{
  "name": "Vitals Publisher (Python 3.11)",
  "dockerFile": "Dockerfile",
  "context": ".",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "eamodio.gitlens",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.formatting.provider": "black",
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "ms-python.black-formatter"
        }
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && pip install pytest pytest-cov black flake8 mypy pylint isort pytest-mock",
  "postStartCommand": "mkdir -p /etc/mosquitto/conf.d /run/mosquitto && printf 'listener 1883\nallow_anonymous true\n\nlistener 9001\nprotocol websockets\nallow_anonymous true\n' > /etc/mosquitto/conf.d/docker.conf && mosquitto -c /etc/mosquitto/conf.d/docker.conf -d",
  "forwardPorts": [1883, 9001],
  "portsAttributes": {
    "1883": {
      "label": "MQTT Broker (TCP)",
      "onAutoForward": "silent"
    },
    "9001": {
      "label": "MQTT Broker (WebSocket)",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "root",
  "remoteEnv": {
    "HISTSIZE": "10000",
    "HISTFILESIZE": "100000"
  }
}